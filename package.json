{
    "name": "dscope-desktop",
    "version": "1.0.0",
    "description": "DScope Linux Disk Usage Intelligence",
    "main": "electron/main.js",
    "scripts": {
        "start": "electron .",
        "dist": "electron-builder"
    },
    "author": {
        "name": "DScope Team",
        "email": "support@dscope.app"
    },
    "license": "ISC",
    "build": {
        "appId": "com.dscope.app",
        "productName": "DScope",
        "files": [
            "electron/main.js",
            "electron/preload.js",
            "electron/index.html",
            "client/dist/**/*",
            "server/**/*"
        ],
        "directories": {
            "output": "dist",
            "buildResources": "assets"
        },
        "linux": {
            "target": [
                "AppImage",
                "deb",
                "rpm"
            ],
            "category": "Utility",
            "icon": "client/src/assets/DScope_image.png"
        }
    },
    "devDependencies": {
        "electron": "^40.0.0",
        "electron-builder": "^26.7.0"
    }
}